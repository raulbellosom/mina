# Core Appwrite config (required)
APPWRITE_ENDPOINT=https://localhost/v1
APPWRITE_PROJECT_ID=
APPWRITE_DATABASE_ID=mina_db

# Server-side scripts only (never expose in frontend bundles)
APPWRITE_API_KEY=

# Collections (required)
APPWRITE_COLLECTION_USERS_PROFILE=users_profile
APPWRITE_COLLECTION_MATERIAL_CATEGORIES=material_categories
APPWRITE_COLLECTION_MATERIALS=materials
APPWRITE_COLLECTION_CLIENTS=clients
APPWRITE_COLLECTION_DRIVERS=drivers
APPWRITE_COLLECTION_TRUCKS=trucks
APPWRITE_COLLECTION_PLANTS=plants
APPWRITE_COLLECTION_VOUCHERS=vouchers
APPWRITE_COLLECTION_TICKETS=tickets
APPWRITE_COLLECTION_PRINT_LOGS=print_logs
APPWRITE_COLLECTION_AUDIT_LOGS=audit_logs
APPWRITE_COLLECTION_SYSTEM_CONFIG=system_config
APPWRITE_COLLECTION_ROLES=roles
APPWRITE_COLLECTION_PERMISSIONS_CATALOG=permissions_catalog
APPWRITE_COLLECTION_ROLE_PERMISSIONS=role_permissions
APPWRITE_COLLECTION_COUNTER_SALES=counter_sales
APPWRITE_COLLECTION_WEIGHT_LOGS=weight_logs
APPWRITE_COLLECTION_SCAN_LOGS=scan_logs

# Storage buckets (required)
APPWRITE_BUCKET_MATERIAL_IMAGES=material_images

# Functions IDs (required)
APPWRITE_FUNCTION_CREATE_USER=create-user
APPWRITE_FUNCTION_SETUP_OWNER=setup-owner
APPWRITE_FUNCTION_SYNC_USER_NAME=sync-user-name

# Static document IDs (required)
APPWRITE_DOC_SYSTEM_CONFIG_SINGLETON=singleton

# Frontend security (required for QR HMAC signing/validation)
VITE_QR_SECRET=change-me-with-a-long-random-secret

# Optional metadata
# VITE_APP_VERSION=0.0.0-local

# Note:
# frontend/vite.config.js maps APPWRITE_* to import.meta.env.VITE_APPWRITE_*
# except APPWRITE_API_KEY (blocked on purpose).
